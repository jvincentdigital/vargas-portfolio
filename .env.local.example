# Copy to .env.local and fill in.
# .env.local is gitignored. In production, set these in the Vercel dashboard
# or via `vercel env add <NAME> production`.

# Canonical URL of the deployed site. Used by metadataBase, sitemap.ts, robots.ts.
# Example: https://christianvargas.com  (for local dev you can leave it unset —
# it falls back to https://vargas-portfolio.vercel.app).
NEXT_PUBLIC_SITE_URL=

# Resend (https://resend.com) — powers the contact form at /api/contact.
# Create an API key in the Resend dashboard.
RESEND_API_KEY=

# From header for contact emails. Must be on a Resend-verified sending domain.
# Example: "Portfolio <contact@christianvargas.com>"
# Until a real domain is verified, the contact form will return 500 (misconfigured).
RESEND_FROM=
